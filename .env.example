# VeilChat Configuration
# Copy this file to .env and fill in your values

# ─── LLM Provider Keys ────────────────────────────────────────
# At least one provider API key is required
# Note: all env vars use the VEILCHAT_ prefix
VEILCHAT_OPENAI_API_KEY=sk-your-openai-key-here
VEILCHAT_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional: custom base URLs (e.g. for Azure OpenAI)
# VEILCHAT_OPENAI_BASE_URL=https://api.openai.com/v1
# VEILCHAT_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Ollama local LLM — no API key needed, just set the base URL
# Default: http://localhost:11434/v1
# VEILCHAT_OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Security ─────────────────────────────────────────────────
# REQUIRED: Change this to a random string in production
VEILCHAT_SECRET_KEY=change-me-to-a-random-string

# JWT token lifetime in minutes (default: 1440 = 24 hours)
# VEILCHAT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────
# Default: SQLite in ./data/veilchat.db
# For PostgreSQL: postgresql+asyncpg://user:pass@host/dbname
# VEILCHAT_DATABASE_URL=sqlite+aiosqlite:///data/veilchat.db

# ─── Server ───────────────────────────────────────────────────
# VEILCHAT_HOST=0.0.0.0
# VEILCHAT_PORT=8000
# VEILCHAT_DEBUG=false

# CORS origins (JSON array of allowed origins)
# VEILCHAT_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Sanitization ────────────────────────────────────────────
# VEILCHAT_SANITIZATION_ENABLED=true
# VEILCHAT_MIN_CONFIDENCE_THRESHOLD=0.7

# ─── Default Provider ────────────────────────────────────────
# VEILCHAT_DEFAULT_PROVIDER=openai

# ─── Licensing ──────────────────────────────────────────────
# Path to RS256 public key for offline license validation
# VEILCHAT_LICENSE_PUBLIC_KEY_PATH=/app/keys/public_key.pem

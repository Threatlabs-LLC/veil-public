# VeilProxy Configuration
# Copy this file to .env and set the required values below.
# Everything else has sensible defaults — you can configure it later.

# ─── REQUIRED ────────────────────────────────────────────────
# Generate a random key: openssl rand -base64 32
VEILCHAT_SECRET_KEY=change-me-to-a-random-string

# ─── LLM Provider (at least one) ────────────────────────────
# Set at least one API key, or use Ollama for fully local/air-gapped.
# Users can also add their own keys in Settings after login.
VEILCHAT_OPENAI_API_KEY=
VEILCHAT_ANTHROPIC_API_KEY=

# Ollama (local models, no API key needed)
# VEILCHAT_OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Everything below is optional ────────────────────────────

# Google OAuth ("Continue with Google" on login page)
# Get credentials: https://console.cloud.google.com → APIs → Credentials
# VEILCHAT_GOOGLE_CLIENT_ID=
# VEILCHAT_GOOGLE_CLIENT_SECRET=

# SMTP (password reset emails)
# Without this, users can still log in — they just can't reset forgotten passwords.
# VEILCHAT_SMTP_HOST=smtp.gmail.com
# VEILCHAT_SMTP_PORT=587
# VEILCHAT_SMTP_USER=you@example.com
# VEILCHAT_SMTP_PASSWORD=your-app-password
# VEILCHAT_SMTP_FROM_EMAIL=noreply@yourdomain.com

# Database (default: SQLite, no config needed)
# For PostgreSQL: postgresql+asyncpg://user:pass@host/dbname
# VEILCHAT_DATABASE_URL=sqlite+aiosqlite:///data/veilchat.db

# Redis (optional, for distributed rate limiting in multi-worker setups)
# VEILCHAT_REDIS_URL=redis://localhost:6379/0

# Public URL (set if behind a reverse proxy / custom domain)
# Used for OAuth callbacks and password reset links
# VEILCHAT_APP_BASE_URL=https://yourdomain.com

# CORS (set to your domain if not using default)
# VEILCHAT_CORS_ORIGINS=["https://yourdomain.com"]

# Custom provider endpoints (Azure OpenAI, etc.)
# VEILCHAT_OPENAI_BASE_URL=https://api.openai.com/v1
# VEILCHAT_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# License key (for paid self-hosted tiers)
# VEILCHAT_LICENSE_PUBLIC_KEY_PATH=/app/keys/public_key.pem
